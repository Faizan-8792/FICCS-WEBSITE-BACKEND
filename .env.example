# MySQL Database (Hostinger or local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ficcs_db
DB_USER=root
DB_PASSWORD=your_password

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Admin bootstrap (optional — creates admin on first start)
ADMIN_EMAIL=Theficcs.india@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=FICCS Admin

# Cloudinary (optional — falls back to local /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL(s) for CORS
CLIENT_URL=http://localhost:5173
CLIENT_URLS=

# Contact-inquiry email relay via FormSubmit (https://formsubmit.co) — no SMTP needed.
# Inquiries are forwarded to this address (defaults to the live office email).
# saifullahfaizan786@gmail.com is always CC'd automatically.
# NOTE: first submission to a new address triggers a one-time activation email.
FORMSUBMIT_EMAIL=Theficcs.india@gmail.com
# Optional extra CC recipients (comma-separated).
CONTACT_NOTIFY_EMAILS=

# Google Drive archive of membership submissions (optional).
# Full service-account JSON on ONE line, single-quoted. Leave empty to disable.
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID of a Drive folder you OWN and SHARED with the service-account email (Editor).
# Service accounts have no personal Drive storage, so uploads must go inside a
# folder owned by a real account. Find the ID in the folder URL after /folders/.
GDRIVE_PARENT_FOLDER_ID=
