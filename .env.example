# MySQL Database (Hostinger or local)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ficcs_db
DB_USER=root
DB_PASSWORD=your_password

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Admin bootstrap (optional — creates admin on first start)
ADMIN_EMAIL=Theficcs.india@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=FICCS Admin

# Cloudinary (optional — falls back to local /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend URL(s) for CORS
CLIENT_URL=http://localhost:5173
CLIENT_URLS=

# SMTP for contact-inquiry email notifications (optional — no-ops if unset)
# Gmail: use an App Password, host smtp.gmail.com, port 465.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
# Optional extra recipients (comma-separated). FICCS office email +
# saifullahfaizan786@gmail.com are always included automatically.
CONTACT_NOTIFY_EMAILS=
